<Page x:Class="bilet5.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:bilet5.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid Background="LightGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListView SelectionChanged="ToDoList_SelectionChanged" Name="ToDoList" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="10" HorizontalContentAlignment="Stretch">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel>
                        
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding FormatTitle}" FontSize="25"/>
                        <TextBlock Text="{Binding FormatDesc}" Width="250" Grid.Row="1" FontSize="20" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding FormatStatus}" Grid.Row="2" FontSize="16"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <WrapPanel Orientation="Vertical">
                <TextBlock Text="Название" FontSize="16"/>
                <TextBox Width="200" FontSize="16" Name="TitleText" Text="{Binding Title}"/>
            </WrapPanel>
            <WrapPanel Orientation="Vertical">
                <TextBlock Text="Описание" FontSize="16"/>
                <TextBox Width="200" Height="100" FontSize="16" Name="DescText" Text="{Binding Description}" TextWrapping="Wrap"/>
            </WrapPanel>
            <Button Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click" FontSize="16" Padding="10" Margin="10" Background="AliceBlue"/>
            <Button Name="DeleteBtn" Content="Удалить" Click="DeleteBtn_Click" FontSize="16" Padding="10" Margin="10" Background="AliceBlue"/>
            <Button Name="EditBtn" Content="Выполнить" Click="EditBtn_Click" FontSize="16" Padding="10" Margin="10" Background="AliceBlue"/>
        </StackPanel>
    </Grid>
</Page>
