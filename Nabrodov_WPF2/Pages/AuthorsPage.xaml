<Page x:Class="Nabrodov_WPF2.Pages.AuthorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nabrodov_WPF2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorsPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="AliceBlue">
            <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Имя" FontSize="16" Margin="10"/>
                <TextBox Text="{Binding FirstName}" FontSize="20" Width="200" Margin="10"/>
                <TextBlock Text="Фамилия" FontSize="16" Margin="10"/>
                <TextBox Text="{Binding LastName}" FontSize="20" Width="200" Margin="10"/>
                <TextBlock Text="Портрет" FontSize="16" Margin="10"/>
                <Button Content="Выбрать картинку" FontSize="14" Padding="8" Width="150" Margin="10"/>
                <WrapPanel>
                    <Button Content="Сохранить" Click="AddAuthor_Click" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Left"/>
                    <Button Content="Удалить" Click="DeleteAuthor_Click" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Right"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Column="1" x:Name="AuthorsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Портрет" Binding="{Binding Portrait}" Width="*"/>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Click="EditAuthor_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
