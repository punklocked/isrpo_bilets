<Page x:Class="Nabrodov_WPF2.Pages.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nabrodov_WPF2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SearchPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="AliceBlue">
            <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Поиск" FontSize="16" Margin="10"/>
                <TextBox x:Name="SearchBox" Width="250" Height="30" Margin="10" FontSize="16"/>
                <TextBlock Text="Тип поиска" FontSize="16" Margin="10"/>
                <ComboBox x:Name="SearchType" Width="250" Height="30" SelectedIndex="0" Margin="10" FontSize="16">
                    <ComboBoxItem Content="Название"/>
                    <ComboBoxItem Content="Автор"/>
                    <ComboBoxItem Content="Год выпуска"/>
                    <ComboBoxItem Content="Жанр"/>
                </ComboBox>
                <Button Content="Найти" Click="SearchBooks_Click" FontSize="18" Padding="8" Width="150" Margin="10"/>
                <TextBlock Text="Примечание: Авторы ищутся по фамилии" FontSize="12" Margin="20"/>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Column="1" x:Name="SearchDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Authors.LastName}" Width="*"/>
                <DataGridTextColumn Header="Год выпуска" Binding="{Binding PublicationYear, StringFormat='{}{0:yyyy}'}" Width="*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genres.Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
