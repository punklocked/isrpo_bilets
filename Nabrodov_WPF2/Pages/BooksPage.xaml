<Page x:Class="Nabrodov_WPF2.Pages.BooksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nabrodov_WPF2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BooksPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="AliceBlue">
            <ScrollViewer>
                <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Название" FontSize="16" Margin="10"/>
                    <TextBox Text="{Binding Title}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Автор" FontSize="16" Margin="10"/>
                    <ComboBox Name="AuthorsCBox" SelectedItem="{Binding Authors}" DisplayMemberPath="LastName" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Год выпуска" FontSize="16" Margin="10"/>
                    <DatePicker SelectedDate="{Binding PublicationYear}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Жанр" FontSize="16" Margin="10"/>
                    <ComboBox Name="GenresCBox" SelectedItem="{Binding Genres}" DisplayMemberPath="Name" FontSize="20" Width="200" Margin="10"/>
                    <WrapPanel>
                        <Button Content="Сохранить" Click="AddBook_Click" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Left"/>
                        <Button Content="Удалить" Click="DeleteBook_Click" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Right"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <DataGrid Grid.Column="1" x:Name="BooksDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Authors.LastName}" Width="*"/>
                <DataGridTextColumn Header="Год выпуска" Binding="{Binding PublicationYear, StringFormat='{}{0:yyyy}'}" Width="*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genres.Name}" Width="*"/>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Click="EditBook_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
