<Page x:Class="Nabrodov_UserApp.Pages.LKPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nabrodov_UserApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LKPage">

    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="{Binding fio, StringFormat='Добро пожаловать {0}'}" FontSize="30" TextAlignment="Center" Margin="30"/>
        <Border Width="100" Height="70" CornerRadius="20" Background="Red">
            <Button Content="Выход" Background="Transparent" BorderBrush="Transparent" Foreground="White" FontSize="25" Click="Exit_Click"/>
        </Border>
    </StackPanel>
</Page>
