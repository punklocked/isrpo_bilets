<Page x:Class="nabrodov_shop.Pages.Admin_Pages.ClientEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:nabrodov_shop.Pages.Admin_Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientEdit">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="AliceBlue">
            <ScrollViewer>
                <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Введите логин" FontSize="16" Margin="10"/>
                    <TextBox Text="{Binding Login}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Введите пароль" FontSize="16" Margin="10"/>
                    <TextBox Text="{Binding Password}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Введите ФИО" FontSize="16" Margin="10"/>
                    <TextBox Text="{Binding FIO}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Введите номер телефона" FontSize="16" Margin="10"/>
                    <TextBox Text="{Binding Phone}" FontSize="20" Width="200" Margin="10"/>
                    <TextBlock Text="Роль" FontSize="16" Margin="10"/>
                    <ComboBox Name="RoleCBox" SelectedItem="{Binding Roles}" DisplayMemberPath="RoleName" FontSize="20" Width="200" Margin="10"/>
                    <WrapPanel>
                        <Button Content="Сохранить" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Left" Click="SaveClient_Click"/>
                        <Button Content="Удалить" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Right" Click="DeleteClient_Click"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <DataGrid Grid.Column="1" x:Name="ClientDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID клиента" Binding="{Binding UserId}" Width="*"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="*"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}" Width="*"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding Phone}" Width="*"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="*"/>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Click="EditClient_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
