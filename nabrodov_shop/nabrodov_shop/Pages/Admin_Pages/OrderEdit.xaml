<Page x:Class="nabrodov_shop.Pages.Admin_Pages.OrderEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:nabrodov_shop.Pages.Admin_Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderEdit">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ComboBox Name="StatusCBox" SelectedValue="{Binding Status}" SelectedValuePath="Content" FontSize="20" Width="200" Margin="10">
                <ComboBoxItem Content="Оформлен"/>
                <ComboBoxItem Content="Отправлен"/>
                <ComboBoxItem Content="Доставлен"/>
            </ComboBox>
            <WrapPanel>
                <Button Name="SaveButton" IsEnabled="False" Content="Сохранить" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Left" Click="SaveOrder_Click"/>
                <Button Content="Удалить" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Right" Click="DeleteOrder_CLick"/>
            </WrapPanel>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="OrderDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="OrderDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID заказа" Binding="{Binding OrderId}" Width="*"/>
                    <DataGridTextColumn Header="ID клиента" Binding="{Binding UserId}" Width="*"/>
                    <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate}" Width="*"/>
                    <DataGridTextColumn Header="Стоимость заказа" Binding="{Binding TotalPrice}" Width="*"/>
                    <DataGridTextColumn Header="Статус заказа" Binding="{Binding Status}" Width="*"/>

                    <DataGridTemplateColumn Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Смена статуса заказа" Click="ChangeStatus_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Row="2" Name="ItemsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название товара" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="*"/>
                    <DataGridTextColumn Header="Итого" Binding="{Binding Total}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3">
                <TextBlock Name="TotalPrice" Text="Сумма: " HorizontalAlignment="Left" FontSize="16"/>
                <TextBlock Name="UserOrdered" Text="Пользователь: " HorizontalAlignment="Right" FontSize="16"/>
            </Grid>
        </Grid>
    </Grid>
</Page>