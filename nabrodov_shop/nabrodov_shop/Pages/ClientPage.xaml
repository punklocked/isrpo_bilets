<Page x:Class="nabrodov_shop.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:nabrodov_shop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <WrapPanel Background="AliceBlue" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Login, StringFormat='Добро пожаловать {0}'}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
            <Border Width="100" Height="50" CornerRadius="20" Background="Red" HorizontalAlignment="Right" Margin="300 0 0 0">
                <Button Content="Выход" Background="Transparent" BorderBrush="Transparent" Foreground="White" FontSize="25" Click="Exit_Click"/>
            </Border>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10*"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <ScrollViewer>
                        <ListView x:Name="CartListView">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding ProductName}"/>
                                    <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price}"/>
                                    <GridViewColumn Header="Количество" DisplayMemberBinding="{Binding Quantity}"/>
                                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Total}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </ScrollViewer>
                    <TextBlock Name="TotalPrice" Grid.Row="1" Text="Итого: 0" FontSize="20" VerticalAlignment="Center" Margin="5"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Button Content="Заказать" Width="90" Height="40" HorizontalAlignment="Left" Margin="10" Click="Order_Click"/>
                    <Button Content="Удалить" Width="90" Height="40" HorizontalAlignment="Center" Margin="10" Click="DeleteItem_Click"/>
                    <Button Content="Очистить" Width="90" Height="40" HorizontalAlignment="Right" Margin="10" Click="ClearCart_Click"/>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel x:Name="Form" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                        <ComboBox Name="CategoryCBox" SelectedItem="{Binding Categories}" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId" FontSize="20" Width="200" Margin="10"/>
                        <Button Content="Применить" FontSize="14" Padding="8" Width="90" Margin="10" HorizontalAlignment="Center" Click="SetFilter_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <DataGrid Grid.Column="1" x:Name="ProductDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название продукта" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding Price}" Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Categories.CategoryName}" Width="*"/>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Добавить" Click="AddProduct_Click" CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
